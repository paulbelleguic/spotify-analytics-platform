{
  "name": "Spotify Analytics Theme",
  "dataColors": [
    "#1DB954",
    "#191414",
    "#535353",
    "#B3B3B3",
    "#1ED760",
    "#0F8A3B"
  ],
  "background": "#FFFFFF",
  "foreground": "#191414",
  "tableAccent": "#1DB954",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#191414"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#191414"
              }
            },
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#535353"
              }
            },
            "fontSize": 11
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#1DB954"
              }
            }
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#1DB954"
              }
            }
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#1DB954"
              }
            }
          }
        ]
      }
    }
  }
}
